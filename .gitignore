# ============================================================
# OpenSuno .gitignore
# ============================================================

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# lock files (only keep bun.lock)
package-lock.json
pnpm-lock.yaml
yarn.lock

# ============================================================
# 🔒 SECURITY: Environment & Secrets
# ============================================================
.env
.env.*
!.env.example

# Browser data (contains login sessions — DO NOT COMMIT)
.browser-data/
.browser-real/

# Cookie extraction scripts output
/tmp/
*.log

# Test scripts (may contain sensitive data)
test-clerk-api.js
test-cookie.js
get-cookie*.js
extract-token*.js
manual-extract.sh
MANUAL_COOKIE_GUIDE.md

# ============================================================
# Generated content
# ============================================================
# Music files (generated locally, too large for git)
*.mp3
*.wav
*.ogg
*.flac

# Batch output
/output/
output/

# Progress tracking (contains per-user data)
progress.json

# ============================================================
# Platform
# ============================================================
# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.idea/
.vscode/
*.swp
*.swo

# Extension build output (rebuild with bun run ext:build)
extension/dist/
