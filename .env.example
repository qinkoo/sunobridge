# ============================================================
# SunoBridge — Environment Variables
# ============================================================
# Run "node setup-cookie.js" for interactive setup.
# Cookie must be extracted from https://suno.com/create (NOT homepage!)

# Required: Suno authentication cookie
SUNO_COOKIE=

# Optional: 2captcha API key for automated captcha solving
# Get from https://2captcha.com
TWOCAPTCHA_KEY=

# Optional: Browser config for captcha automation
BROWSER=chromium          # chromium | firefox (chromium recommended)
BROWSER_HEADLESS=true     # true | false
BROWSER_LOCALE=en         # browser locale for captcha pages
BROWSER_GHOST_CURSOR=false  # use ghost cursor (more natural mouse movement)
BROWSER_DISABLE_GPU=false   # set true for Docker/headless environments

# Optional: Custom Chromium path (auto-detected if not set)
# Windows: C:/Program Files/Google/Chrome/Application/chrome.exe
# macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux:   /usr/bin/google-chrome
# CHROME_PATH=

# Optional: HTTP proxy (for users behind firewall/VPN like Clash Verge)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# Optional: MCP server port (default: 3001)
# MCP_PORT=3001

# Optional: Bridge server port (default: 3001)
# BRIDGE_PORT=3001